{
  "name": "@crt-services/timer-e2e",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "implicitDependencies": [
      "@crt-services/timer"
    ],
    "targets": {
      "e2e": {
        "executor": "@nx/jest:jest",
        "outputs": [
          "{projectRoot}/test-output/jest/coverage"
        ],
        "options": {
          "jestConfig": "apps/timer-e2e/jest.config.cts",
          "passWithNoTests": true
        },
        "dependsOn": [
          "@crt-services/timer:build",
          "@crt-services/timer:serve"
        ]
      }
    }
  }
}
