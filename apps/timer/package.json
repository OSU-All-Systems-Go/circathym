{
  "name": "@crt-services/timer",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "targets": {
      "docs": {
        "command": "npx ts-node apps/timer/tools/swagger.ts"
      },
      "build": {
        "executor": "@nx/esbuild:esbuild",
        "outputs": [
          "{options.outputPath}"
        ],
        "defaultConfiguration": "production",
        "options": {
          "platform": "node",
          "outputPath": "apps/timer/dist",
          "format": [
            "cjs"
          ],
          "bundle": false,
          "main": "apps/timer/src/main.ts",
          "tsConfig": "apps/timer/tsconfig.app.json",
          "assets": [
            "apps/timer/src/assets",
            {
              "input": "apps/timer/src/assets",
              "glob": "**/*",
              "output": "assets"
            }
          ],
          "esbuildOptions": {
            "sourcemap": true,
            "outExtension": {
              ".js": ".js"
            }
          }
        },
        "configurations": {
          "development": {},
          "production": {
            "generateLockfile": true,
            "esbuildOptions": {
              "sourcemap": false,
              "outExtension": {
                ".js": ".js"
              }
            }
          }
        }
      },
      "prune-lockfile": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "executor": "@nx/js:prune-lockfile",
        "outputs": [
          "{workspaceRoot}/apps/timer/dist/package.json",
          "{workspaceRoot}/apps/timer/dist/package-lock.json"
        ],
        "options": {
          "buildTarget": "build"
        }
      },
      "copy-workspace-modules": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "outputs": [
          "{workspaceRoot}/apps/timer/dist/workspace_modules"
        ],
        "executor": "@nx/js:copy-workspace-modules",
        "options": {
          "buildTarget": "build"
        }
      },
      "prune": {
        "dependsOn": [
          "prune-lockfile",
          "copy-workspace-modules"
        ],
        "executor": "nx:noop"
      },
      "serve": {
        "continuous": true,
        "executor": "@nx/js:node",
        "defaultConfiguration": "development",
        "dependsOn": [
          "build"
        ],
        "options": {
          "buildTarget": "@crt-services/timer:build",
          "runBuildTargetDependencies": false
        },
        "configurations": {
          "development": {
            "buildTarget": "@crt-services/timer:build:development"
          },
          "production": {
            "buildTarget": "@crt-services/timer:build:production"
          }
        }
      },
      "test": {
        "options": {
          "passWithNoTests": true
        }
      },
      "docker:build": {
        "dependsOn": [
          "build",
          "prune"
        ]
      },
      "cdk:deploy": {
        "dependsOn": [
          "build",
          "prune"
        ],
        "executor": "nx:run-commands",
        "options": {
          "command": "cdk deploy \"*Stack\" --require-approval never -a \"npx ts-node --prefer-ts-exts ./apps/timer/iac/stack/index.ts\""
        }
      }
    }
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1045.0",
    "@aws-sdk/client-secrets-manager": "^3.1043.0",
    "@aws-sdk/lib-dynamodb": "^3.1045.0",
    "@fastify/autoload": "~6.0.3",
    "@fastify/aws-lambda": "^6.4.0",
    "@fastify/cors": "11.2.0",
    "@fastify/forwarded": "3.0.1",
    "@fastify/passport": "^3.0.2",
    "@fastify/secure-session": "^8.3.0",
    "@fastify/sensible": "~6.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/passport-jwt": "^4.0.1",
    "axios": "^1.6.0",
    "crypto": "^1.0.1",
    "fastify": "~5.2.1",
    "fastify-plugin": "~5.0.1",
    "jsonwebtoken": "^9.0.3",
    "passport-jwt": "^4.0.1",
    "passport-local": "~1.0.0"
  },
  "devDependencies": {
    "@fastify/swagger": "9.7.0",
    "@fastify/swagger-ui": "5.2.6",
    "@types/node": "^25.8.0",
    "@types/pg": "8.20.0",
    "aws-cdk": "^2.1121.0",
    "aws-cdk-lib": "^2.253.1"
  }
}
